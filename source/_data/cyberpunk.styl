/* 流浪地球科幻风 — 配色方案 */
:root {
  --cyber-primary: #2979FF;      /* 地球发动机蓝 */
  --cyber-secondary: #FF6D00;    /* 推进器火焰橙 */
  --cyber-accent: #00E5FF;       /* 等离子冰青 */
  --cyber-alert: #FF1744;        /* 警报红 */
  --cyber-purple: #7C4DFF;       /* 木星极光紫 */
  --cyber-dark: #0A1628;         /* 深空黑 */
  --cyber-darker: #060E1A;       /* 更深空 */
  --cyber-card: #1A2332;         /* 卡片面板 */
  --cyber-light: #E8F0FE;        /* 冰白蓝文字 */
  --cyber-grid: rgba(41, 121, 255, 0.06);
  --cyber-glow: rgba(41, 121, 255, 0.35);
}

/* eDEX-UI 网格背景效果 */
body::before {
  content: '';
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-image: 
    linear-gradient(var(--cyber-grid) 1px, transparent 1px),
    linear-gradient(90deg, var(--cyber-grid) 1px, transparent 1px);
  background-size: 50px 50px;
  background-position: center center;
  pointer-events: none;
  z-index: -2;
  opacity: 0.4;
}

/* eDEX-UI 扫描线效果 */
body::after {
  content: '';
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: repeating-linear-gradient(
    0deg,
    rgba(0, 0, 0, 0.15) 0px,
    rgba(0, 0, 0, 0.15) 1px,
    transparent 1px,
    transparent 2px
  );
  pointer-events: none;
  z-index: 10000;
  opacity: 0.3;
}

/* 故障艺术效果 - 标题 */
.site-title, .site-brand {
  position: relative;
  text-shadow:
    2px 0 var(--cyber-secondary),
    -2px 0 var(--cyber-purple);
  animation: cyber-glitch 4s infinite;
}

@keyframes cyber-glitch {
  0% {
    text-shadow: 2px 0 var(--cyber-secondary), -2px 0 var(--cyber-purple);
  }
  25% {
    text-shadow: -2px 0 var(--cyber-secondary), 2px 0 var(--cyber-purple);
  }
  50% {
    text-shadow: 2px 0 var(--cyber-purple), -2px 0 var(--cyber-accent);
  }
  75% {
    text-shadow: -2px 0 var(--cyber-purple), 2px 0 var(--cyber-accent);
  }
  100% {
    text-shadow: 2px 0 var(--cyber-secondary), -2px 0 var(--cyber-purple);
  }
}

/* 导航栏赛博风格 */
.main-menu {
  background: linear-gradient(90deg,
    rgba(10, 22, 40, 0.95) 0%,
    rgba(26, 35, 50, 0.95) 50%,
    rgba(10, 22, 40, 0.95) 100%);
  border-bottom: 2px solid var(--cyber-primary);
  box-shadow: 0 0 20px rgba(41, 121, 255, 0.25);
}

.menu-item a:hover {
  color: var(--cyber-primary);
  text-shadow: 0 0 10px var(--cyber-primary);
  transition: all 0.3s ease;
}

/* 文章卡片效果 */
.post-block {
  position: relative;
  background: linear-gradient(135deg,
    var(--cyber-card) 0%,
    var(--cyber-darker) 100%);
  border: 1px solid rgba(41, 121, 255, 0.2);
  box-shadow:
    0 0 15px rgba(41, 121, 255, 0.08),
    inset 0 0 30px rgba(41, 121, 255, 0.03);
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

.post-block:hover {
  transform: translateY(-5px);
  border-color: var(--cyber-primary);
  box-shadow:
    0 0 30px rgba(41, 121, 255, 0.25),
    0 0 60px rgba(124, 77, 255, 0.1),
    inset 0 0 50px rgba(41, 121, 255, 0.08);
}

/* 代码块赛博风格 */
.highlight-container {
  background: linear-gradient(135deg,
    #0D1628 0%,
    #1A2332 100%);
  border: 1px solid rgba(41, 121, 255, 0.25);
  box-shadow: 0 0 20px rgba(41, 121, 255, 0.08);
}

.highlight figcaption {
  background: rgba(41, 121, 255, 0.08);
  border-bottom: 1px solid rgba(41, 121, 255, 0.25);
  color: var(--cyber-accent);
  font-family: 'Courier New', monospace;
  text-transform: uppercase;
  letter-spacing: 2px;
}

/* 按钮效果 */
.btn {
  position: relative;
  overflow: hidden;
  background: transparent;
  border: 2px solid var(--cyber-primary);
  color: var(--cyber-primary);
  box-shadow: 0 0 10px rgba(41, 121, 255, 0.3);
  transition: all 0.3s ease;
}

.btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg,
    transparent,
    rgba(41, 121, 255, 0.4),
    transparent);
  transition: left 0.5s ease;
}

.btn:hover::before {
  left: 100%;
}

.btn:hover {
  background: var(--cyber-primary);
  color: var(--cyber-darker);
  box-shadow: 0 0 30px rgba(41, 121, 255, 0.6);
}

/* 暗黑模式增强 */
body.dark-mode {
  background: var(--cyber-darker);
}

body.dark-mode .main-content {
  color: var(--cyber-light);
}

body.dark-mode .post-body h1,
body.dark-mode .post-body h2,
body.dark-mode .post-body h3 {
  color: var(--cyber-primary);
  text-shadow: 0 0 10px rgba(41, 121, 255, 0.5);
}

body.dark-mode a {
  color: var(--cyber-secondary);
  transition: color 0.3s ease;
}

body.dark-mode a:hover {
  color: var(--cyber-accent);
  text-shadow: 0 0 8px var(--cyber-accent);
}

/* 时间线控制效果 */
.timeline-indicator {
  position: fixed;
  right: 20px;
  bottom: 20px;
  width: 60px;
  height: 60px;
  background: rgba(10, 22, 40, 0.9);
  border: 2px solid var(--cyber-primary);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 0 20px rgba(41, 121, 255, 0.35);
  z-index: 1000;
  cursor: pointer;
  transition: all 0.3s ease;
}

.timeline-indicator:hover {
  transform: scale(1.1);
  box-shadow: 0 0 30px rgba(41, 121, 255, 0.7), 0 0 60px rgba(124, 77, 255, 0.3);
}

/* 阅读进度条赛博风格 */
.reading-progress-bar {
  background: linear-gradient(90deg,
    var(--cyber-primary),
    var(--cyber-purple),
    var(--cyber-secondary));
  box-shadow: 0 0 10px rgba(41, 121, 255, 0.6);
}

/* 标签和分类徽章 */
.post-meta .category,
.post-meta .tag {
  background: rgba(41, 121, 255, 0.1);
  border: 1px solid var(--cyber-primary);
  color: var(--cyber-accent);
  padding: 2px 8px;
  border-radius: 3px;
  transition: all 0.3s ease;
}

.post-meta .category:hover,
.post-meta .tag:hover {
  background: var(--cyber-primary);
  color: var(--cyber-light);
  box-shadow: 0 0 15px rgba(41, 121, 255, 0.6);
}

/* 搜索框效果 */
.search-input-container input {
  background: rgba(10, 22, 40, 0.8);
  border: 2px solid rgba(41, 121, 255, 0.3);
  color: var(--cyber-light);
  transition: all 0.3s ease;
}

.search-input-container input:focus {
  border-color: var(--cyber-primary);
  box-shadow: 0 0 20px rgba(41, 121, 255, 0.4);
}

/* 页脚效果 */
.footer {
  background: linear-gradient(180deg,
    rgba(10, 22, 40, 0.9) 0%,
    rgba(6, 14, 26, 0.95) 100%);
  border-top: 2px solid var(--cyber-secondary);
  box-shadow: 0 -5px 20px rgba(255, 109, 0, 0.15);
}

/* 响应式优化 */
@media (max-width: 768px) {
  .site-title {
    font-size: 1.5rem;
  }
  
  .post-block {
    margin: 10px;
  }
}
