// ============================================================
// 流浪地球科幻风 — 配色方案
// ============================================================
$cyber-primary = #2979FF      // 地球发动机蓝
$cyber-secondary = #FF6D00    // 推进器火焰橙
$cyber-accent = #00E5FF       // 等离子冰青
$cyber-alert = #FF1744        // 警报红
$cyber-purple = #7C4DFF       // 木星极光紫
$body-bg = #0A1628            // 深空黑
$card-bg = #1A2332            // 卡片面板
$text-color = #E8F0FE         // 冰白蓝
$primary-color = #2979FF      // 主蓝
$accent-color = #00E5FF       // 冰青

// eDEX-UI 风格故障艺术标题
.site-title, .site-brand, .post-title
  position: relative
  text-shadow: 
    2px 0 var(--cyber-secondary, #ff6b00),
    -2px 0 var(--cyber-primary, #00ffea)
  animation: cyber-glitch 3s infinite

@keyframes cyber-glitch
  0%
    text-shadow: 2px 0 var(--cyber-secondary, #ff6b00), -2px 0 var(--cyber-primary, #00ffea)
  25%
    text-shadow: -2px 0 var(--cyber-secondary, #ff6b00), 2px 0 var(--cyber-primary, #00ffea)
  50%
    text-shadow: 2px 0 var(--cyber-secondary, #ff6b00), -2px 0 var(--cyber-primary, #00ffea)
  75%
    text-shadow: -2px 0 var(--cyber-secondary, #ff6b00), 2px 0 var(--cyber-primary, #00ffea)
  100%
    text-shadow: 2px 0 var(--cyber-secondary, #ff6b00), -2px 0 var(--cyber-primary, #00ffea)

// 代码块
.highlight-container
  position: relative
  background: linear-gradient(135deg, #0D1628 0%, #1A2332 100%)
  border: 1px solid rgba(41, 121, 255, 0.25)
  box-shadow: 0 0 20px rgba(41, 121, 255, 0.08)

  &::before
    content: ''
    position: absolute
    top: 0
    left: 0
    width: 100%
    height: 2px
    background: rgba(0, 229, 255, 0.25)
    box-shadow: 0 0 10px rgba(0, 229, 255, 0.4)
    animation: code-scan 3s linear infinite
    pointer-events: none

@keyframes code-scan
  0%
    top: 0%
  100%
    top: 100%

// 按钮样式
.btn
  position: relative
  overflow: hidden
  background: transparent
  border: 2px solid $cyber-primary
  color: $cyber-primary
  box-shadow: 0 0 10px rgba(41, 121, 255, 0.25)
  transition: all 0.3s ease

  &::before
    content: ''
    position: absolute
    top: 0
    left: -100%
    width: 100%
    height: 100%
    background: linear-gradient(90deg, transparent, rgba(41, 121, 255, 0.3), transparent)
    transition: left 0.5s ease

  &:hover::before
    left: 100%

  &:hover
    background: $cyber-primary
    color: $cyber-darker
    box-shadow: 0 0 30px rgba(41, 121, 255, 0.5)

// 暗黑模式增强
body.dark-mode
  background: #060E1A

  .main-content
    color: $cyber-light

  .post-body h1,
  .post-body h2,
  .post-body h3
    color: $cyber-primary
    text-shadow: 0 0 10px rgba(41, 121, 255, 0.5)

  a
    color: $cyber-secondary
    transition: color 0.3s ease

    &:hover
      color: $cyber-accent
      text-shadow: 0 0 8px rgba(0, 229, 255, 0.5)

// 时间线指示器
.timeline-indicator
  position: fixed
  right: 20px
  bottom: 20px
  width: 60px
  height: 60px
  background: rgba(6, 14, 26, 0.9)
  border: 2px solid $cyber-primary
  border-radius: 50%
  display: flex
  align-items: center
  justify-content: center
  box-shadow: 0 0 20px rgba(41, 121, 255, 0.35)
  z-index: 1000
  cursor: pointer
  transition: all 0.3s ease

  &:hover
    transform: scale(1.1)
    box-shadow: 0 0 30px rgba(41, 121, 255, 0.6), 0 0 60px rgba(124, 77, 255, 0.25)

// 阅读进度条
.reading-progress-bar
  background: linear-gradient(90deg, $cyber-primary, $cyber-purple, $cyber-secondary)
  box-shadow: 0 0 10px rgba(41, 121, 255, 0.6)

// 标签和分类徽章
.post-meta .category,
.post-meta .tag
  background: rgba(41, 121, 255, 0.1)
  border: 1px solid $cyber-primary
  color: $cyber-accent
  padding: 2px 8px
  border-radius: 3px
  transition: all 0.3s ease

  &:hover
    background: $cyber-primary
    color: $cyber-light
    box-shadow: 0 0 15px rgba(41, 121, 255, 0.6)

// 搜索框
.search-input-container input
  background: rgba(6, 14, 26, 0.8)
  border: 2px solid rgba(41, 121, 255, 0.3)
  color: $cyber-light
  transition: all 0.3s ease

  &:focus
    border-color: $cyber-primary
    box-shadow: 0 0 20px rgba(41, 121, 255, 0.4)

// 页脚
.footer
  background: linear-gradient(180deg, rgba(10, 22, 40, 0.95), rgba(6, 14, 26, 0.98))
  border-top: 2px solid $cyber-secondary
  box-shadow: 0 -5px 20px rgba(255, 109, 0, 0.15)

// 响应式优化
@media (max-width: 768px)
  .site-title
    font-size: 1.5rem
  
  .post-block
    margin: 10px

// 背景和文字的基础样式
body
  color: $text-color
  font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif
  font-weight: 300
  line-height: 1.7
  min-height: 100vh
  position: relative
  overflow-x: hidden

// ============================================================
// 统一的 body::before — 多层叠加背景
// 使用 CSS 多背景叠加：星空 → 科技网格 → 底色
// ============================================================
body::before
  content: ''
  position: fixed
  top: 0
  left: 0
  width: 100%
  height: 100%
  pointer-events: none
  z-index: -2
  /* CSS 多背景：星空粒子 + 科技网格 + 底色 */
  background:
    radial-gradient(1.5px 1.5px at 50px 50px, #90CAF9, transparent),
    radial-gradient(1px 1px at 100px 150px, $cyber-accent, transparent),
    radial-gradient(1px 1px at 200px 80px, $cyber-primary, transparent),
    radial-gradient(1px 1px at 250px 200px, #90CAF9, transparent),
    radial-gradient(1px 1px at 300px 100px, $cyber-accent, transparent),
    radial-gradient(1px 1px at 400px 180px, $cyber-primary, transparent),
    radial-gradient(1px 1px at 500px 60px, #90CAF9, transparent),
    radial-gradient(1px 1px at 600px 220px, $cyber-accent, transparent),
    radial-gradient(1px 1px at 700px 120px, $cyber-primary, transparent),
    radial-gradient(1px 1px at 50px 250px, #90CAF9, transparent),
    radial-gradient(1px 1px at 150px 300px, $cyber-accent, transparent),
    radial-gradient(1px 1px at 350px 350px, $cyber-primary, transparent),

    linear-gradient(rgba(41, 121, 255, 0.04) 1px, transparent 1px),
    linear-gradient(90deg, rgba(41, 121, 255, 0.04) 1px, transparent 1px),

    $body-bg
  background-repeat: repeat, repeat, repeat, repeat, repeat, repeat, repeat, repeat, repeat, repeat, repeat, repeat, repeat, repeat, no-repeat
  background-size:
    300px 300px, 300px 300px, 300px 300px, 300px 300px,
    300px 300px, 300px 300px, 300px 300px, 300px 300px,
    300px 300px, 300px 300px, 300px 300px, 300px 300px,
    40px 40px, 40px 40px, auto

// ============================================================
// 统一的 body::after — CRT 扫描线 + 能量场叠加效果
// ============================================================
body::after
  content: ''
  position: fixed
  top: 0
  left: 0
  width: 100%
  height: 100%
  pointer-events: none
  z-index: 10000
  /* CRT 扫描线 + 能量场辉光 */
  background:
    repeating-linear-gradient(
      0deg,
      rgba(0, 0, 0, 0.15) 0px,
      rgba(0, 0, 0, 0.15) 1px,
      transparent 1px,
      transparent 2px
    ),
    radial-gradient(
      circle at center,
      transparent 0%,
      rgba(41, 121, 255, 0.04) 70%,
      rgba(124, 77, 255, 0.06) 100%
    )
  opacity: 0.3
  animation: energy-field 20s infinite alternate

// 添加能量场动画
@keyframes energy-field
  0%
    transform: scale(1)
    opacity: 0.3
  100%
    transform: scale(1.05)
    opacity: 0.5

// 添加扫描线效果
.scan-line
  position: fixed
  top: 0
  left: 0
  width: 100%
  height: 8px
  background: linear-gradient(
    to bottom,
    rgba(0, 229, 255, 0) 0%,
    rgba(0, 229, 255, 0.2) 50%,
    rgba(0, 229, 255, 0) 100%
  )
  z-index: -996
  animation: scan 8s linear infinite
  pointer-events: none

@keyframes scan
  0%
    top: 0
    opacity: 0
  10%
    opacity: 0.5
  50%
    opacity: 1
  90%
    opacity: 0.5
  100%
    top: 100%
    opacity: 0

/* 电路板纹理 */
.circuit-pattern
  position: fixed
  top: 0
  left: 0
  width: 100%
  height: 100%
  background-image: 
    linear-gradient(rgba(41, 121, 255, 0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(41, 121, 255, 0.03) 1px, transparent 1px),
    radial-gradient(circle at 10% 20%, rgba(41, 121, 255, 0.05) 0.1px, transparent 0.1px),
    radial-gradient(circle at 20% 40%, rgba(41, 121, 255, 0.05) 0.1px, transparent 0.1px),
    radial-gradient(circle at 30% 60%, rgba(41, 121, 255, 0.05) 0.1px, transparent 0.1px),
    radial-gradient(circle at 40% 80%, rgba(41, 121, 255, 0.05) 0.1px, transparent 0.1px),
    radial-gradient(circle at 60% 10%, rgba(41, 121, 255, 0.05) 0.1px, transparent 0.1px),
    radial-gradient(circle at 70% 30%, rgba(41, 121, 255, 0.05) 0.1px, transparent 0.1px),
    radial-gradient(circle at 80% 50%, rgba(41, 121, 255, 0.05) 0.1px, transparent 0.1px),
    radial-gradient(circle at 90% 70%, rgba(41, 121, 255, 0.05) 0.1px, transparent 0.1px)
  background-size: 
    60px 60px,
    60px 60px,
    100px 100px,
    100px 100px,
    100px 100px,
    100px 100px,
    100px 100px,
    100px 100px,
    100px 100px,
    100px 100px
  z-index: -995
  pointer-events: none
  animation: circuit-pulse 15s infinite alternate

// 添加高级霓虹光效
.neon-glow
  position: relative
  &::before
    content: ''
    position: absolute
    top: -5px
    left: -5px
    right: -5px
    bottom: -5px
    border: 2px solid rgba(41, 121, 255, 0.6)
    border-radius: inherit
    filter: blur(10px)
    z-index: -1
    animation: neon-pulse 3s infinite alternate

@keyframes neon-pulse
  0%
    opacity: 0.3
    box-shadow: 0 0 10px rgba(41, 121, 255, 0.3)
  100%
    opacity: 0.8
    box-shadow: 0 0 20px rgba(41, 121, 255, 0.6)

// 添加全息投影效果
.hologram-effect
  position: relative
  overflow: hidden
  &::after
    content: ''
    position: absolute
    top: -50%
    left: -60%
    width: 20px
    height: 200%
    background: rgba(255, 255, 255, 0.3)
    transform: rotate(25deg)
    transition: all 0.6s

.hologram-effect:hover::after
  left: 120%
  transition: left 0.6s

// 添加浮动粒子效果
.floating-particles
  position: fixed
  top: 0
  left: 0
  width: 100%
  height: 100%
  pointer-events: none
  z-index: -1

.particle
  position: absolute
  border-radius: 50%
  background: rgba(41, 121, 255, 0.6)
  animation: float 15s infinite linear

@keyframes float
  0%
    transform: translateY(0) rotate(0deg)
    opacity: 0
  10%
    opacity: 1
  90%
    opacity: 1
  100%
    transform: translateY(-100vh) rotate(360deg)
    opacity: 0

// 添加科技按钮样式
.button-tech
  background: linear-gradient(45deg, rgba(41, 121, 255, 0.1), rgba(41, 121, 255, 0.3))
  border: 1px solid rgba(41, 121, 255, 0.5)
  color: $cyber-primary
  padding: 12px 24px
  border-radius: 6px
  cursor: pointer
  transition: all 0.3s ease
  position: relative
  overflow: hidden
  font-family: 'Orbitron', 'Segoe UI', sans-serif

.button-tech:hover
  background: linear-gradient(45deg, rgba(41, 121, 255, 0.3), rgba(41, 121, 255, 0.5))
  box-shadow: 0 0 15px rgba(41, 121, 255, 0.5)
  color: $cyber-light
  transform: translateY(-2px)

// 添加数据流效果
.data-stream-bar
  position: fixed
  top: 0
  left: 0
  width: 100%
  height: 4px
  background: linear-gradient(90deg, transparent, rgba(41, 121, 255, 0.8), transparent)
  animation: data-flow 2s linear infinite
  z-index: 9999
  pointer-events: none

@keyframes data-flow
  0%
    transform: translateX(-100%)
  100%
    transform: translateX(100%)

// 添加高级文字效果
.advanced-text-glow
  position: relative
  color: #e8f4fd
  text-shadow: 
    0 0 5px rgba(41, 121, 255, 0.5),
    0 0 10px rgba(41, 121, 255, 0.3),
    0 0 15px rgba(41, 121, 255, 0.2)

// 添加脉冲效果
.pulse-element
  animation: pulse-animation 2s infinite

@keyframes pulse-animation
  0%
    box-shadow: 0 0 0 0 rgba(41, 121, 255, 0.7)
  70%
    box-shadow: 0 0 0 15px rgba(41, 121, 255, 0)
  100%
    box-shadow: 0 0 0 0 rgba(41, 121, 255, 0)

// 添加高级导航样式
.nav-tech
  background: rgba(20, 40, 60, 0.8)
  backdrop-filter: none
  border-bottom: 1px solid rgba(41, 121, 255, 0.3)
  padding: 15px 0

.nav-tech .menu-item a
  color: #90CAF9
  padding: 10px 20px
  border-radius: 5px
  transition: all 0.3s ease
  position: relative
  overflow: hidden

.nav-tech .menu-item a::before
  content: ''
  position: absolute
  top: 0
  left: -100%
  width: 100%
  height: 100%
  background: linear-gradient(90deg, transparent, rgba(41, 121, 255, 0.2), transparent)
  transition: left 0.5s

.nav-tech .menu-item a:hover::before
  left: 100%

.nav-tech .menu-item a:hover
  color: $cyber-primary
  background: rgba(41, 121, 255, 0.1)
  text-shadow: 0 0 8px rgba(41, 121, 255, 0.6)

// 页面整体容器
html, body
  background: $body-bg
  font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif
  color: #e8f4fd  // 更亮的文字颜色
  min-height: 100vh
  position: relative
  overflow-x: hidden

// 黑客帝国风格电路背景
.hacker-background {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -1005;
  pointer-events: none;
  
  &::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: 
      linear-gradient(rgba(0, 255, 128, 0.05) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 255, 128, 0.05) 1px, transparent 1px);
    background-size: 40px 40px;
  }
}

// 电路板连线效果
.circuit-lines {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -1004;
  pointer-events: none;
  
  &::before,
  &::after {
    content: '';
    position: absolute;
    width: 100%;
    height: 100%;
    
    // 水平和垂直连线
    background-image: 
      linear-gradient(transparent 49%, rgba(0, 255, 128, 0.2) 50%, transparent 51%),
      linear-gradient(90deg, transparent 49%, rgba(0, 255, 128, 0.2) 50%, transparent 51%);
    background-size: 100px 100px;
  }
  
  &::after {
    // 斜向连线
    background-image: 
      linear-gradient(45deg, transparent 49%, rgba(0, 255, 128, 0.1) 50%, transparent 51%),
      linear-gradient(-45deg, transparent 49%, rgba(0, 255, 128, 0.1) 50%, transparent 51%);
    background-size: 100px 100px;
  }
}

// 数据流效果
.data-flow {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -1003;
  pointer-events: none;
  overflow: hidden;
  
  .flow-line {
    position: absolute;
    height: 2px;
    background: linear-gradient(90deg, transparent, rgba(0, 255, 128, 0.8), rgba(0, 255, 128, 0.5), transparent);
    animation: flow-data 8s linear infinite;
    
    // 随机位置和速度
    &:nth-child(1) { top: 10%; animation-delay: 0s; }
    &:nth-child(2) { top: 20%; animation-delay: 2s; }
    &:nth-child(3) { top: 30%; animation-delay: 4s; }
    &:nth-child(4) { top: 40%; animation-delay: 1s; }
    &:nth-child(5) { top: 50%; animation-delay: 3s; }
    &:nth-child(6) { top: 60%; animation-delay: 5s; }
    &:nth-child(7) { top: 70%; animation-delay: 2s; }
    &:nth-child(8) { top: 80%; animation-delay: 4s; }
    &:nth-child(9) { top: 90%; animation-delay: 6s; }
  }
}

@keyframes flow-data {
  0% {
    left: -100px;
    width: 100px;
  }
  100% {
    left: 100%;
    width: 100px;
  }
}

// 黑客代码雨效果
.matrix-code {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -1002;
  pointer-events: none;
  color: rgba(0, 255, 128, 0.05);
  font-size: 14px;
  font-family: monospace;
  letter-spacing: 2px;
  overflow: hidden;
  white-space: nowrap;
}

// 脉冲节点效果
.pulse-nodes {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -1001;
  pointer-events: none;
  
  .pulse-node {
    position: absolute;
    width: 8px;
    height: 8px;
    background: rgba(0, 255, 128, 0.6);
    border-radius: 50%;
    animation: pulse-glow 2s infinite;
    
    // 随机分布
    &:nth-child(1) { top: 15%; left: 10%; animation-delay: 0s; }
    &:nth-child(2) { top: 25%; left: 20%; animation-delay: 0.5s; }
    &:nth-child(3) { top: 35%; left: 80%; animation-delay: 1s; }
    &:nth-child(4) { top: 45%; left: 70%; animation-delay: 1.5s; }
    &:nth-child(5) { top: 55%; left: 30%; animation-delay: 0s; }
    &:nth-child(6) { top: 65%; left: 60%; animation-delay: 0.8s; }
    &:nth-child(7) { top: 75%; left: 40%; animation-delay: 1.2s; }
    &:nth-child(8) { top: 85%; left: 90%; animation-delay: 0.3s; }
  }
}

@keyframes pulse-glow {
  0%, 100% {
    box-shadow: 0 0 5px rgba(0, 255, 128, 0.6);
    transform: scale(1);
  }
  50% {
    box-shadow: 0 0 20px rgba(0, 255, 128, 0.9), 0 0 30px rgba(0, 255, 128, 0.5);
    transform: scale(1.5);
  }
}

// 增强型动态粒子背景
.particle-field {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: -1002;
  overflow: hidden;
}

.particle {
  position: absolute;
  border-radius: 50%;
  background: rgba(41, 121, 255, 0.3);
  animation: float-particle linear infinite;
}

@keyframes float-particle {
  0% {
    transform: translate(0, 0);
    opacity: 0;
  }
  10% {
    opacity: 1;
  }
  90% {
    opacity: 0.5;
  }
  100% {
    transform: translate(var(--tx), var(--ty));
    opacity: 0;
  }
}

// 数据流效果
.data-stream {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: -1003;
  overflow: hidden;
  
  .stream-line {
    position: absolute;
    height: 2px;
    background: linear-gradient(90deg, transparent, rgba(41, 121, 255, 0.6), transparent);
    animation: stream-move 15s linear infinite;
  }
}

@keyframes stream-move {
  0% {
    transform: translateX(-100vw);
  }
  100% {
    transform: translateX(100vw);
  }
}

// 全息投影效果
.holographic-effect {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: -1004;
  background: 
    radial-gradient(circle at 20% 30%, rgba(41, 121, 255, 0.05) 0%, transparent 20%),
    radial-gradient(circle at 80% 70%, rgba(41, 121, 255, 0.05) 0%, transparent 20%);
  animation: holographic-float 20s ease-in-out infinite;
}

@keyframes holographic-float {
  0%, 100% {
    opacity: 0.3;
    transform: rotate(0deg);
  }
  50% {
    opacity: 0.5;
    transform: rotate(1deg);
  }
}

// 能量场效果
.energy-field {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: -1005;
  
  &::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 100px;
    height: 100px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(41, 121, 255, 0.1) 0%, transparent 70%);
    animation: energy-pulse 8s ease-in-out infinite;
  }
}

@keyframes energy-pulse {
  0%, 100% {
    transform: translate(-50%, -50%) scale(1);
    opacity: 0.5;
  }
  50% {
    transform: translate(-50%, -50%) scale(1.5);
    opacity: 0.2;
  }
}

// 扫描线效果
.scan-line {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: -1006;
  background: linear-gradient(to bottom, transparent 0%, rgba(41, 121, 255, 0.05) 1%, transparent 2%);
  animation: scan-animation 8s linear infinite;
}

@keyframes scan-animation {
  0% {
    transform: translateY(-100%);
  }
  100% {
    transform: translateY(100%);
  }
}

// 简洁的导航弹窗样式
.nav-modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(10, 15, 30, 0.9);
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
  
  &.active {
    opacity: 1;
    visibility: visible;
  }
}

.nav-modal-content {
  background: rgba(20, 40, 60, 0.95);
  border: 1px solid rgba(41, 121, 255, 0.6);
  border-radius: 12px;
  padding: 30px;
  width: 90%;
  max-width: 400px;
  box-shadow: 0 0 30px rgba(41, 121, 255, 0.3);
  text-align: center;
}

.nav-modal-header {
  margin-bottom: 20px;
  
  h3 {
    margin: 0;
    color: $cyber-primary;
    font-size: 1.5em;
  }
}

.nav-modal-close {
  position: absolute;
  top: 15px;
  right: 15px;
  background: transparent;
  border: none;
  color: $cyber-light;
  font-size: 1.5em;
  cursor: pointer;
  width: 30px;
  height: 30px;
  border-radius: 50%;
  transition: all 0.3s ease;
  
  &:hover {
    background: rgba(41, 121, 255, 0.2);
    color: $cyber-primary;
    transform: scale(1.1);
  }
}

.nav-modal-menu {
  list-style: none;
  padding: 0;
  margin: 0;
  
  li {
    margin-bottom: 12px;
    
    &:last-child {
      margin-bottom: 0;
    }
    
    a {
      display: block;
      padding: 15px;
      color: $cyber-light;
      text-decoration: none;
      border-radius: 8px;
      transition: all 0.3s ease;
      border: 1px solid rgba(41, 121, 255, 0.2);
      
      &:hover {
        background: rgba(41, 121, 255, 0.2);
        color: $cyber-primary;
        border-color: rgba(41, 121, 255, 0.4);
        transform: translateY(-2px);
      }
      
      i {
        margin-right: 10px;
        width: 20px;
        text-align: center;
      }
    }
  }
}

// 简洁的导航按钮样式
.nav-toggle-btn {
  position: fixed;
  top: 20px;
  right: 20px;
  z-index: 1000;
  background: rgba(41, 121, 255, 0.2);
  border: 1px solid rgba(41, 121, 255, 0.4);
  border-radius: 50%;
  width: 50px;
  height: 50px;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all 0.3s ease;
  backdrop-filter: blur(5px);
  
  &:hover {
    background: rgba(41, 121, 255, 0.3);
    transform: scale(1.1);
    box-shadow: 0 0 15px rgba(41, 121, 255, 0.4);
  }
  
  .menu-icon {
    display: flex;
    flex-direction: column;
    width: 20px;
    height: 16px;
    justify-content: space-between;
    
    span {
      display: block;
      height: 2px;
      width: 100%;
      background: #80deea;
      border-radius: 1px;
      transition: all 0.3s ease;
    }
  }
}

// 平滑过渡动画
* {
  transition: background-color 0.3s ease, border-color 0.3s ease, color 0.3s ease, box-shadow 0.3s ease, transform 0.3s ease;
}

// 标题样式 - 使用科幻字体，分层颜色
h1, h2, h3, h4, h5, h6
  font-family: 'Orbitron', 'Segoe UI', sans-serif
  margin: 20px 0 15px 0
  font-weight: 500
  text-rendering: optimizeLegibility
  -webkit-font-smoothing: antialiased

h1
  font-size: 2.2em
  color: $cyber-primary  // 地球发动机蓝
  text-shadow: 0 0 5px rgba(41, 121, 255, 0.6), 0 0 15px rgba(41, 121, 255, 0.3)

h2
  font-size: 1.8em
  color: $cyber-accent  // 等离子冰青
  text-shadow: 0 0 5px rgba(0, 229, 255, 0.5), 0 0 12px rgba(0, 229, 255, 0.25)

h3
  font-size: 1.5em
  color: #B388FF  // 淡紫（极光）
  text-shadow: 0 0 5px rgba(124, 77, 255, 0.4), 0 0 10px rgba(124, 77, 255, 0.2)

h4
  color: $text-color
  font-size: 1.2em

// 链接样式
a
  color: $cyber-accent  // 冰青
  text-decoration: none
  transition: all 0.3s ease
  border-bottom: 1px solid transparent
  text-shadow: 0 0 2px rgba(0, 229, 255, 0.2)

a:hover
  color: $cyber-light
  border-bottom: 1px solid $cyber-accent
  text-shadow: 0 0 8px rgba(0, 229, 255, 0.5)
  background: rgba(41, 121, 255, 0.08)
  padding: 2px 4px
  border-radius: 3px

// 卡片和区块样式
.post-block, .sidebar, .header, .footer, .card
  background: $card-bg
  border: 1px solid rgba(41, 121, 255, 0.3)
  box-shadow:
    0 0 25px rgba(41, 121, 255, 0.12),
    inset 0 0 15px rgba(41, 121, 255, 0.06)
  border-radius: 8px
  padding: 25px
  position: relative
  overflow: hidden
  transition: all 0.3s ease

.post-block:hover, .sidebar:hover, .header:hover, .footer:hover, .card:hover
  box-shadow:
    0 0 35px rgba(41, 121, 255, 0.2),
    inset 0 0 20px rgba(41, 121, 255, 0.1),
    0 0 50px rgba(124, 77, 255, 0.08)
  transform: translateY(-3px)

// 添加科技感边框修饰
.post-block::before, .sidebar::before, .header::before, .footer::before, .card::before
  content: ''
  position: absolute
  top: -2px
  left: -2px
  right: -2px
  bottom: -2px
  border-radius: 10px
  z-index: -1
  border: 1px solid transparent
  background: linear-gradient(45deg, rgba(41, 121, 255, 0.08), rgba(124, 77, 255, 0.2), rgba(0, 229, 255, 0.08), rgba(41, 121, 255, 0.2))
  background-origin: border-box
  background-clip: content-box, border-box
  animation: borderAnimation 4s linear infinite

// 添加内部发光效果
.post-block::after, .sidebar::after, .header::after, .footer::after, .card::after
  content: ''
  position: absolute
  top: 0
  left: 0
  width: 100%
  height: 100%
  border-radius: 8px
  box-shadow: 
    inset 0 0 15px rgba(41, 121, 255, 0.15),
    inset 0 0 30px rgba(41, 121, 255, 0.1)
  z-index: -1

// 导航菜单
.main-menu
  background: linear-gradient(135deg, rgba(16, 28, 46, 0.97), rgba(26, 35, 50, 0.95))
  border: 1px solid rgba(41, 121, 255, 0.3)
  box-shadow: 0 0 20px rgba(41, 121, 255, 0.15)
  border-radius: 8px
  padding: 10px

.menu-item a
  color: $text-color
  padding: 12px 20px
  border-radius: 6px
  transition: all 0.3s ease
  border: 1px solid transparent
  font-family: 'Segoe UI', sans-serif

.menu-item a:hover
  color: $cyber-accent
  background: rgba(41, 121, 255, 0.12)
  border: 1px solid rgba(41, 121, 255, 0.25)
  box-shadow: 0 0 15px rgba(41, 121, 255, 0.2)

// 输入框样式
input[type="text"], input[type="search"], textarea
  background: rgba(10, 26, 42, 0.5)
  border: 1px solid rgba(41, 121, 255, 0.3)
  color: $text-color
  padding: 10px 15px
  border-radius: 4px
  font-family: 'Segoe UI', sans-serif

input[type="text"]:focus, input[type="search"]:focus, textarea:focus
  outline: none
  border: 1px solid $primary-color
  box-shadow: 0 0 10px rgba(41, 121, 255, 0.5)

// 滚动条样式
::-webkit-scrollbar
  width: 10px

::-webkit-scrollbar-track
  background: rgba(10, 26, 42, 0.3)

::-webkit-scrollbar-thumb
  background: linear-gradient(to bottom, $primary-color, $accent-color)
  border-radius: 5px

// 文本选择样式
::selection
  background: rgba(41, 121, 255, 0.3)
  color: #ffffff

::-moz-selection
  background: rgba(41, 121, 255, 0.3)
  color: #ffffff

// 分页导航
.pagination .page-number, 
.pagination .prev, 
.pagination .next
  background: rgba(10, 26, 42, 0.5)
  border: 1px solid rgba(41, 121, 255, 0.3)
  color: $text-color
  padding: 8px 15px
  border-radius: 4px

.pagination .page-number:hover, 
.pagination .prev:hover, 
.pagination .next:hover
  background: rgba(41, 121, 255, 0.2)
  border: 1px solid $primary-color
  color: #ffffff

// 标签样式
.tag
  background: rgba(41, 121, 255, 0.1)
  border: 1px solid rgba(41, 121, 255, 0.3)
  color: $primary-color
  padding: 4px 10px
  border-radius: 20px

.tag:hover
  background: rgba(41, 121, 255, 0.3)
  box-shadow: 0 0 10px rgba(41, 121, 255, 0.5)

// 代码块样式
.codeblock
  background: rgba(0, 0, 0, 0.3)
  border: 1px solid rgba(41, 121, 255, 0.3)
  border-radius: 6px

// 引用块样式
blockquote
  border-left: 3px solid $primary-color
  background: rgba(41, 121, 255, 0.05)
  padding: 15px 20px
  margin: 20px 0
  border-radius: 0 4px 4px 0
  color: #90CAF9

// 文章内容区域
.post-body
  color: $text-color
  line-height: 1.8
  font-size: 16px
  letter-spacing: 0.5px
  text-rendering: optimizeLegibility
  -webkit-font-smoothing: antialiased

// 文章标题样式
.post-title
  font-family: 'Orbitron', 'Segoe UI', sans-serif
  color: $cyber-primary  // 亮蓝色
  text-shadow: 0 0 3px rgba(41, 121, 255, 0.5), 0 0 8px rgba(41, 121, 255, 0.3)
  font-weight: 500
  text-rendering: optimizeLegibility
  -webkit-font-smoothing: antialiased
  transition: all 0.3s ease

.post-title-link
  color: $cyber-primary  // 亮蓝色
  text-decoration: none
  transition: all 0.3s ease
  border-bottom: 1px solid transparent
  display: block
  padding: 5px 0

.post-title-link:hover
  color: $cyber-accent
  border-bottom: 1px solid $cyber-accent
  text-shadow: 0 0 8px rgba(0, 229, 255, 0.5)
  background: rgba(41, 121, 255, 0.08)
  padding: 5px 8px
  border-radius: 3px

// 搜索弹窗样式
.search-pop-overlay {
  background: rgba(6, 14, 26, 0.96)
}

.popup {
  background: rgba(16, 28, 46, 0.98)
  border: 1px solid rgba(41, 121, 255, 0.4)
  box-shadow: 0 0 30px rgba(41, 121, 255, 0.3), 0 0 10px rgba(124, 77, 255, 0.15) inset
  border-radius: 8px
  color: $text-color
  font-family: 'Segoe UI', 'Orbitron', sans-serif

  .search-header {
    border-bottom: 1px solid rgba(41, 121, 255, 0.3)

    .search-input-container {
      input {
        background: rgba(6, 14, 26, 0.7)
        border: 1px solid rgba(41, 121, 255, 0.35)
        color: $text-color
        padding: 12px 15px
        border-radius: 6px
        font-family: 'Segoe UI', sans-serif

        &:focus {
          border: 1px solid $cyber-primary
          box-shadow: 0 0 15px rgba(41, 121, 255, 0.4)
        }
      }
    }

    .popup-btn-close {
      color: $cyber-primary
      transition: all 0.3s ease

      &:hover {
        color: $cyber-accent
        text-shadow: 0 0 10px rgba(0, 229, 255, 0.5)
      }
    }
  }

  .search-result-container {
    .search-result {
      border-bottom: 1px solid rgba(41, 121, 255, 0.15)

      .search-result-title {
        color: $cyber-primary
        transition: all 0.3s ease

        &:hover {
          color: $cyber-accent
          text-shadow: 0 0 8px rgba(0, 229, 255, 0.4)
          padding-left: 5px
        }
      }

      .search-result-item {
        border-left: 2px solid rgba(41, 121, 255, 0.2)

        &:hover {
          border-left: 2px solid $cyber-primary
          background: rgba(41, 121, 255, 0.08)
        }
      }
    }

    .search-result-icon {
      color: $cyber-primary
      text-align: center
      font-size: 24px
    }
  }
}

// 侧边栏整体样式
.sidebar {
  background: rgba(16, 28, 46, 0.97)
  border: 1px solid rgba(41, 121, 255, 0.35)
  box-shadow:
    0 0 25px rgba(41, 121, 255, 0.15),
    inset 0 0 15px rgba(41, 121, 255, 0.08)
  border-radius: 8px
  color: $text-color
  padding: 20px

  // 侧边栏标题
  .sidebar-title {
    color: $cyber-primary
    border-bottom: 1px solid rgba(41, 121, 255, 0.3)
    text-shadow: 0 0 5px rgba(41, 121, 255, 0.35)
    font-family: 'Orbitron', 'Segoe UI', sans-serif
    margin-bottom: 15px
    padding-bottom: 10px
  }

  // 侧边栏菜单项
  .sidebar-nav {
    margin: 0
    padding: 0

    & > li {
      border-left: 2px solid transparent
      transition: all 0.3s ease

      &:hover {
        border-left: 2px solid $cyber-primary
        background: rgba(41, 121, 255, 0.08)
        transform: translateX(5px)
      }

      &.active {
        border-left: 2px solid $cyber-primary
        background: rgba(41, 121, 255, 0.12)
      }

      a {
        color: $text-color
        padding: 8px 15px
        display: block
        transition: all 0.3s ease
        border-radius: 4px

        &:hover {
          color: $cyber-accent
          background: rgba(41, 121, 255, 0.12)
          text-shadow: 0 0 8px rgba(0, 229, 255, 0.4)
        }

        &.active {
          color: $cyber-light
          background: rgba(41, 121, 255, 0.18)
          border-left: 2px solid $cyber-primary
        }
      }
    }
  }

  // 侧边栏面板容器
  .sidebar-panel-container {
    background: rgba(16, 28, 46, 0.95)
    border: 1px solid rgba(41, 121, 255, 0.35)
    box-shadow: 0 0 25px rgba(41, 121, 255, 0.15)
    border-radius: 8px
    padding: 15px

    // 侧边栏概览
    .site-overview {
      .site-author {
        .site-author-name {
          color: $cyber-primary
          text-shadow: 0 0 5px rgba(41, 121, 255, 0.35)
          margin-bottom: 10px
        }

        .site-description {
          color: #90CAF9
          font-size: 14px
        }
      }

      .site-state {
        border-top: 1px solid rgba(41, 121, 255, 0.25)

        .site-state-item {
          a {
            border-bottom: none

            .site-state-item-name {
              color: #90CAF9
            }

            .site-state-item-value {
              color: $cyber-primary
              text-shadow: 0 0 5px rgba(41, 121, 255, 0.35)
            }
          }
        }
      }
    }

    // 侧边栏文章目录
    .post-toc {
      .post-toc-title {
        color: $cyber-primary
        text-shadow: 0 0 5px rgba(41, 121, 255, 0.35)
        border-bottom: 1px solid rgba(41, 121, 255, 0.25)
        padding-bottom: 8px
        margin-bottom: 10px
      }

      .post-toc ol {
        padding-left: 15px

        > li {
          margin: 8px 0

          > ol {
            padding-left: 12px

            > li {
              margin: 6px 0

              a {
                color: #90CAF9
                transition: all 0.3s ease

                &:hover {
                  color: $cyber-accent
                  text-shadow: 0 0 8px rgba(0, 229, 255, 0.4)
                }
              }
            }
          }

          > a {
            color: $cyber-primary
            transition: all 0.3s ease
            display: block
            padding: 3px 5px
            border-radius: 3px

            &:hover {
              color: $cyber-light
              background: rgba(41, 121, 255, 0.1)
              text-shadow: 0 0 8px rgba(0, 229, 255, 0.4)
            }

            &.active {
              color: $cyber-light
              background: rgba(41, 121, 255, 0.18)
              border-left: 2px solid $cyber-primary
            }
          }
        }
      }
    }
  }
}

// 侧边栏开关按钮
.sidebar-toggle {
  background: rgba(41, 121, 255, 0.15)
  border: 1px solid rgba(41, 121, 255, 0.35)
  border-radius: 5px
  transition: all 0.3s ease

  &:hover {
    background: rgba(41, 121, 255, 0.25)
    box-shadow: 0 0 15px rgba(41, 121, 255, 0.4)
  }

  .toggle-line {
    background: $cyber-accent
  }
}

// 侧边栏遮罩
// Pisces 方案下侧边栏始终显示，不需要遮罩
.sidebar-dimmer {
  display: none !important;
}

// 完全隐藏侧边栏
.sidebar {
  transition: all 0.4s ease
  z-index: 1001
  
  &.hidden {
    transform: translateX(-100%)
    opacity: 0
    pointer-events: none
  }
}

// 社交链接样式
.sidebar-social {
  margin-top: 20px
  padding-top: 15px
  border-top: 1px solid rgba(41, 121, 255, 0.25)

  .social-item {
    display: inline-block
    margin: 0 8px
    width: 36px
    height: 36px
    line-height: 36px
    text-align: center
    border-radius: 50%
    background: rgba(41, 121, 255, 0.08)
    border: 1px solid rgba(41, 121, 255, 0.25)
    color: $cyber-primary
    transition: all 0.3s ease

    &:hover {
      background: rgba(41, 121, 255, 0.25)
      color: $cyber-accent
      border: 1px solid rgba(0, 229, 255, 0.5)
      text-shadow: 0 0 8px rgba(0, 229, 255, 0.5)
      transform: scale(1.1)
    }
  }
}

// 侧边栏标签云
.sidebar-tags {
  margin-top: 20px
  padding-top: 15px
  border-top: 1px solid rgba(41, 121, 255, 0.25)

  .sidebar-tag-item {
    display: inline-block
    margin: 4px 3px
    padding: 3px 10px
    background: rgba(41, 121, 255, 0.08)
    border: 1px solid rgba(41, 121, 255, 0.15)
    border-radius: 12px
    color: #90CAF9
    font-size: 12px
    transition: all 0.3s ease

    &:hover {
      background: rgba(124, 77, 255, 0.2)
      color: $cyber-accent
      border: 1px solid rgba(124, 77, 255, 0.35)
      text-shadow: 0 0 8px rgba(0, 229, 255, 0.4)
    }
  }
}

// 侧边栏归档
.sidebar-archives {
  margin-top: 20px
  padding-top: 15px
  border-top: 1px solid rgba(41, 121, 255, 0.25)

  .archive-item {
    padding: 5px 0
    border-left: 2px solid transparent
    transition: all 0.3s ease

    &:hover {
      border-left: 2px solid $cyber-primary
      background: rgba(41, 121, 255, 0.08)
      padding-left: 8px
    }

    .archive-link {
      color: #90CAF9
      transition: all 0.3s ease

      &:hover {
        color: $cyber-accent
        text-shadow: 0 0 8px rgba(0, 229, 255, 0.4)
      }
    }

    .archive-count {
      float: right
      color: $cyber-primary
      font-size: 12px
    }
  }
}

// 侧边栏分类
.sidebar-categories {
  margin-top: 20px
  padding-top: 15px
  border-top: 1px solid rgba(41, 121, 255, 0.25)

  .category-item {
    padding: 5px 0
    border-left: 2px solid transparent
    transition: all 0.3s ease

    &:hover {
      border-left: 2px solid $cyber-primary
      background: rgba(41, 121, 255, 0.08)
      padding-left: 8px
    }

    .category-link {
      color: #90CAF9
      transition: all 0.3s ease

      &:hover {
        color: $cyber-accent
        text-shadow: 0 0 8px rgba(0, 229, 255, 0.4)
      }
    }

    .category-count {
      float: right
      color: $cyber-primary
      font-size: 12px
    }
  }
}

// 侧边栏最近文章
.sidebar-recent-posts {
  margin-top: 20px
  padding-top: 15px
  border-top: 1px solid rgba(41, 121, 255, 0.25)

  .recent-post-item {
    padding: 8px 0
    border-bottom: 1px solid rgba(41, 121, 255, 0.08)

    &:last-child {
      border-bottom: none
    }

    .recent-post-title {
      color: $cyber-primary
      font-size: 14px
      transition: all 0.3s ease

      &:hover {
        color: $cyber-accent
        text-shadow: 0 0 8px rgba(0, 229, 255, 0.4)
        padding-left: 5px
      }
    }

    .recent-post-date {
      color: #90CAF9
      font-size: 12px
      margin-top: 3px
    }
  }
}

// 侧边栏搜索框
.sidebar-search {
  margin-top: 20px
  padding: 15px
  background: rgba(6, 14, 26, 0.3)
  border: 1px solid rgba(41, 121, 255, 0.15)
  border-radius: 6px

  .search-input {
    width: 100%
    padding: 8px 12px
    background: rgba(6, 14, 26, 0.5)
    border: 1px solid rgba(41, 121, 255, 0.25)
    border-radius: 4px
    color: $text-color
    font-family: 'Segoe UI', sans-serif
    transition: all 0.3s ease

    &:focus {
      outline: none
      border: 1px solid $cyber-primary
      box-shadow: 0 0 10px rgba(41, 121, 255, 0.35)
    }
  }
}

// 提示框样式
.note
  border-radius: 6px
  padding: 15px
  margin: 20px 0
  border-left: 4px solid

.note.default
  background: rgba(41, 121, 255, 0.1)
  border-color: $primary-color
  color: $text-color

.note.primary
  background: rgba(126, 87, 194, 0.1)
  border-color: #7e57c2
  color: #d1c4e9

.note.info
  background: rgba(33, 150, 243, 0.1)
  border-color: $accent-color
  color: #90CAF9

.note.success
  background: rgba(76, 175, 80, 0.1)
  border-color: #81c784
  color: #c8e6c9

.note.warning
  background: rgba(255, 152, 0, 0.1)
  border-color: #ffb74d
  color: #ffe0b2

.note.danger
  background: rgba(244, 67, 54, 0.1)
  border-color: #e57373
  color: #ffcdd2

// 打字机效果和加载屏幕样式
.loading-screen
  position: fixed
  top: 0
  left: 0
  width: 100%
  height: 100%
  background: #060E1A
  z-index: 10001
  display: flex
  align-items: center
  justify-content: center
  overflow: hidden

.typewriter-container
  width: 80%
  max-width: 700px
  padding: 30px
  display: flex
  flex-direction: column
  font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif
  color: $cyber-light
  overflow: hidden
  position: relative

.typewriter-content
  width: 100%
  display: flex
  flex-direction: column
  justify-content: center
  align-items: center
  text-align: center

.typewriter-header
  display: flex
  align-items: center
  justify-content: center

.typewriter-text
  color: $cyber-accent
  display: inline-block
  font-size: 2.5em
  font-weight: 300
  letter-spacing: 2px
  text-shadow: 0 0 10px rgba(0, 229, 255, 0.5), 0 0 20px rgba(41, 121, 255, 0.3)

.cursor
  display: inline-block
  width: 4px
  height: 1.2em
  background: $cyber-primary
  margin-left: 8px
  animation: blink 1s infinite
  vertical-align: middle
  box-shadow: 0 0 8px $cyber-primary

@keyframes blink
  0%, 100%
    opacity: 1
  50%
    opacity: 0

// 防止页面在加载时滚动
body.loading
  overflow: hidden

// 加载时隐藏 CRT 扫描线和背景特效
body.loading::before
  display: none

body.loading::after
  display: none

// 加载画面样式加强
.loading-screen
  .typewriter-container
    display: flex
    align-items: center
    justify-content: center

  .typewriter-text
    font-size: 3em
    color: #00E5FF
    text-shadow: 0 0 20px rgba(0, 229, 255, 0.8), 0 0 40px rgba(41, 121, 255, 0.4)
    letter-spacing: 4px

  .cursor
    background: #2979FF
    box-shadow: 0 0 10px #2979FF
    width: 3px
    height: 1.5em